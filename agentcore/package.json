{
  "name": "agentcore",
  "version": "1.0.0",
  "description": "Multi-tenant AI agent orchestration platform",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:workers": "tsx watch src/queues/workers.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:workers": "node dist/queues/workers.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/websocket": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.1",
    "imapflow": "^1.2.10",
    "ioredis": "^5.4.0",
    "mammoth": "^1.11.0",
    "node-pop3": "^0.11.0",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
