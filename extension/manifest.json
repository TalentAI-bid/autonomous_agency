{
  "manifest_version": 3,
  "name": "TalentAI Workspace",
  "short_name": "TalentAI",
  "version": "1.0.12",
  "description": "Save LinkedIn pages to your TalentAI workspace for lead research and recruitment.",

  "key": "",

  "update_url": "https://agents.api.talentailabs.com/extension/updates.xml",

  "permissions": ["storage", "activeTab", "scripting", "alarms", "tabs"],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.google.com/maps*",
    "*://www.google.com/maps*",
    "*://*.crunchbase.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/in/*", "*://linkedin.com/in/*"],
      "js": ["content/linkedin/profile-sidebar.js"],
      "run_at": "document_idle"
    }
  ]
}
